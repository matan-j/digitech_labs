# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# internal planning docs (not product source)
SYSTEM digitech lab/

# generated sample outputs / dev scripts (not part of the deployed app)
notebooklm-infographic.html
test-pipeline.ts
test-research-only.ts

# claude-code local-machine settings (keep settings.json shared)
.claude/settings.local.json

# supabase CLI cache (contains DB pooler URL with credentials — must never be committed)
supabase/.temp/
